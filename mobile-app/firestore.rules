rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Recipes: world-readable, only admin-writable via Cloud Functions
    match /recipes/{recipeId} {
      allow read: if true;
      allow write: if false;
    }

    // Ingredients dictionary: world-readable
    match /ingredients/{token} {
      allow read: if true;
      allow write: if false;
    }

    // Users: owner read/write only
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // Client may update mutable preferences; immutable fields enforced server-side.
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['premium', 'stats', 'created_at']);
      allow delete: if false; // Use purgeUserData callable instead

      // Favorites sub-collection
      match /favorites/{recipeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Shopping lists: must be premium
      match /shopping_lists/{listId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null
                     && request.auth.uid == uid
                     && get(/databases/$(database)/documents/users/$(uid))
                          .data.premium.active == true;
      }

      // Cooking history (private)
      match /cooking_history/{historyId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
